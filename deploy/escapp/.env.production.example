# ==========================================================================
# ESC-App – Produktions-Umgebungsvariablen
# ==========================================================================
# Diese Datei nach /opt/escapp/.env kopieren und Werte anpassen!
# NIEMALS in Git einchecken!
# ==========================================================================

# ── Allgemein ─────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Datenbank (MariaDB im Docker-Container) ──────────────────────────────
DB_HOST=mariadb
DB_PORT=33306
DB_NAME=escapp
DB_USER=escapp
DB_PASSWORD=HIER_SICHERES_PASSWORT_SETZEN
DB_ROOT_PASSWORD=HIER_ROOT_PASSWORT_SETZEN

# ── JWT Secrets (mind. 32 Zeichen, zufällig generiert) ────────────────────
JWT_ACCESS_SECRET=HIER_ZUFAELLIGES_SECRET_SETZEN
JWT_REFRESH_SECRET=HIER_ZUFAELLIGES_SECRET_SETZEN
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://esc.basisadresse.de

# ── Admin Bootstrap (erster Admin-Benutzer) ───────────────────────────────
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=HIER_ADMIN_PASSWORT_SETZEN
ADMIN_BOOTSTRAP_DISPLAY_NAME=Administrator

# ── Domains (für Skripte) ────────────────────────────────────────────────
WEB_DOMAIN=esc.basisadresse.de
API_DOMAIN=api.basisadresse.de
API_PATH=/escappapi

# ── Git Repository ───────────────────────────────────────────────────────
GIT_REPO=https://github.com/tobiit/ESC-App.git
GIT_BRANCH=main

# ── Pfade (normalerweise nicht ändern) ────────────────────────────────────
APP_DIR=/opt/escapp
WEB_ROOT=/var/www/esc.basisadresse.de
BACKUP_DIR=/opt/escapp/backups

# ── E-Mail für Let's Encrypt (für Zertifikats-Benachrichtigungen) ────────
CERTBOT_EMAIL=admin@basisadresse.de
