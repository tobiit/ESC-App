    "esc:backend:test": "cd backend && npm test",
    "esc:frontend:test": "cd frontend && npm test",
    "esc:integration": "./scripts/integration-test.sh",
    "tokens:import": "node scripts/import-design-tokens.mjs",
    "tokens:import:escapp": "node scripts/import-design-tokens.mjs design-tokens/source/design-tokens-main/tokens"
  }
}
