{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./build/design-tokens-builder",
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"types": ["node", "fs-extra", "prompts", "semver", "signale", "lodash"],
		"baseUrl": "./src",
		"paths": {
			"shared/*": ["shared/*"]
		}
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "build", "tokens", "token-package", "src/**/*.spec.ts", "src/**/*.mock.spec.ts"]
}
