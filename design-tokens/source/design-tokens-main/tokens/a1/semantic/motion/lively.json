{
  "semantic": {
    "easing-coordinate": {
      "default": {
        "change": {
          "x1": {
            "$type": "number",
            "$value": "0.25"
          },
          "y1": {
            "$type": "number",
            "$value": "0.1"
          },
          "x2": {
            "$type": "number",
            "$value": "0.25"
          },
          "y2": {
            "$type": "number",
            "$value": "1"
          }
        },
        "enter": {
          "x1": {
            "$type": "number",
            "$value": "0"
          },
          "y1": {
            "$type": "number",
            "$value": "0"
          },
          "x2": {
            "$type": "number",
            "$value": "0.58"
          },
          "y2": {
            "$type": "number",
            "$value": "1"
          }
        },
        "exit": {
          "x1": {
            "$type": "number",
            "$value": "0.42"
          },
          "y1": {
            "$type": "number",
            "$value": "0"
          },
          "x2": {
            "$type": "number",
            "$value": "1"
          },
          "y2": {
            "$type": "number",
            "$value": "1"
          }
        }
      }
    },
    "duration": {
      "static": {
        "fast": {
          "$type": "other",
          "$value": "{core.duration.100}"
        },
        "medium": {
          "$type": "other",
          "$value": "{core.duration.250}"
        },
        "slow": {
          "$type": "other",
          "$value": "{core.duration.500}"
        },
        "modifier": {
          "slow-to-fast": {
            "$type": "other",
            "$value": "1",
            "$description": "Enables motion theming be changing (reducing) timings via calculations, similar to the spacing modification system"
          },
          "slow-to-medium": {
            "$type": "other",
            "$value": "1",
            "$description": "Enables motion theming be changing (reducing) timings via calculations, similar to the spacing modification system"
          },
          "medium-to-fast": {
            "$type": "other",
            "$value": "1",
            "$description": "Enables motion theming be changing (reducing) timings via calculations, similar to the spacing modification system"
          }
        }
      },
      "dynamic": {
        "slow-to-fast": {
          "$type": "other",
          "$value": "{core.duration.500}"
        },
        "slow-to-medium": {
          "$type": "other",
          "$value": "{core.duration.500}"
        },
        "medium-to-fast": {
          "$type": "other",
          "$value": "{core.duration.250}"
        }
      }
    },
    "transition": {
      "focus": {
        "duration": {
          "$type": "other",
          "$value": "{semantic.duration.static.fast}"
        },
        "easing": {
          "$type": "other",
          "$value": "{semantic.easing.default.change}"
        }
      }
    },
    "easing": {
      "default": {
        "change": {
          "$type": "other",
          "$value": "{semantic.easing-coordinate.default.change.x1}, {semantic.easing-coordinate.default.change.y1}, {semantic.easing-coordinate.default.change.x2}, {semantic.easing-coordinate.default.change.y2}"
        },
        "enter": {
          "$type": "other",
          "$value": "{semantic.easing-coordinate.default.enter.x1}, {semantic.easing-coordinate.default.enter.y1}, {semantic.easing-coordinate.default.enter.x2}, {semantic.easing-coordinate.default.enter.y2}"
        },
        "exit": {
          "$type": "other",
          "$value": "{semantic.easing-coordinate.default.exit.x1}, {semantic.easing-coordinate.default.exit.y1}, {semantic.easing-coordinate.default.exit.x2}, {semantic.easing-coordinate.default.exit.y2}"
        }
      }
    },
    "scaling": {
      "initial": {
        "$type": "number",
        "$value": "{core.scaling.100}"
      },
      "shrink": {
        "s": {
          "$type": "number",
          "$value": "{core.scaling.75}"
        },
        "m": {
          "$type": "number",
          "$value": "{core.scaling.50}"
        },
        "l": {
          "$type": "number",
          "$value": "{core.scaling.25}"
        }
      }
    }
  }
}