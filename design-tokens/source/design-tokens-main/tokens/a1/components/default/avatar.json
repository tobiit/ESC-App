{
  "avatar": {
    "s": {
      "size": {
        "$type": "sizing",
        "$value": "{semantic.size.component.800}"
      },
      "icon": {
        "size": {
          "$type": "sizing",
          "$value": "(ceil({semantic.size.component.800} * {semantic.internal.size.component.ratio.icon}))"
        }
      },
      "font-size": {
        "$type": "fontSizes",
        "$value": "(ceil({avatar.s.size} * {semantic.internal.size.component.ratio.text}))"
      },
      "text": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{core.font-family.primary}",
          "fontWeight": "{core.font-weight.150}",
          "fontSize": "{avatar.s.font-size}",
          "lineHeight": "{avatar.s.size}",
          "textCase": "{core.text-case.uppercase}",
