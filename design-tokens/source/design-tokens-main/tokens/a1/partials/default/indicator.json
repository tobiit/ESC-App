{
  "indicator": {
    "internal": {
      "component": {
        "size": {
          "factor": {
            "$type": "number",
            "$value": "0.25",
            "$description": "Together with the treshold, scales the indicator in relation to the component size"
          },
          "treshold": {
            "$type": "number",
            "$value": "{core.dimension.100}",
            "$description": "Together with the factor, scales the indicator in relation to the component size"
          }
        },
        "countless": {
          "size": {
            "factor": {
              "$type": "number",
              "$value": "0.175",
              "$description": "Together with the treshold, scales the indicator in relation to the component size"
            },
            "treshold": {
              "$type": "number",
              "$value": "{core.dimension.100}",
              "$description": "Together with the factor, scales the indicator in relation to the component size"
            }
          }
        }
      },
      "content": {
        "size": {
          "factor": {
            "$type": "number",
            "$value": "0.25",
            "$description": "Together with the treshold, scales the indicator in relation to the component size"
          },
          "treshold": {
            "$type": "number",
            "$value": "{core.dimension.250}",
