            },
            "treshold": {
              "$type": "number",
              "$value": "{core.dimension.100}",
              "$description": "Together with the factor, scales the indicator in relation to the component size"
            }
          }
        }
      },
      "count": {
        "font-size": {
          "factor": {
            "$type": "number",
            "$value": "0.75"
          }
        },
        "inset": {
          "factor": {
            "$type": "number",
            "$value": "3",
            "$description": "Calculates the padding left and right for count indicators with more than one character"
          }
        }
      }
    },
    "component": {
      "800": {
        "size": {
          "$type": "sizing",
          "$value": "({semantic.size.component.800} * {indicator.internal.component.size.factor} + {indicator.internal.component.size.treshold})"
        },
        "line-height": {
          "$type": "lineHeights",
          "$value": "{indicator.component.800.size}"
        },
        "countless": {
          "size": {
            "$type": "sizing",
            "$value": "(round({semantic.size.component.800} * {indicator.internal.component.countless.size.factor} + {indicator.internal.component.countless.size.treshold}))"
          }
        },
        "font-size": {
          "$type": "fontSizes",
          "$value": "(ceil({indicator.internal.count.font-size.factor} * {indicator.component.800.size}))"
        },
        "text": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{core.font-family.primary}",
            "fontWeight": "{core.font-weight.150}",
            "fontSize": "{indicator.component.800.font-size}",
            "lineHeight": "{indicator.component.800.line-height}"
          }
        },
        "inset": {
          "horizontal": {
            "$type": "spacing",
            "$value": "(roundTo({indicator.component.800.size} / {indicator.internal.count.inset.factor}, 1))"
          }
        }
      },
